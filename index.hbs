<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{basics.name}} — Resume</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <main class="grid">
    <section>
      <header>
        <img src="{{basics.image}}" alt="{{basics.name}}">
        <div>
          <h1>{{basics.name}}</h1>
          <div class="muted">{{basics.label}}</div>
          <div class="muted" style="margin-top:6px">
            {{basics.location.city}}, {{basics.location.countryCode}} • {{basics.phone}} •
            <a href="mailto:{{basics.email}}">{{basics.email}}</a>
          </div>
        </div>
      </header>

      <div class="section">
        <h2>Summary</h2>
        <p class="muted">{{basics.summary}}</p>
      </div>

      <div class="section">
        <h2>Work</h2>

        {{#work}}
        <div style="margin-bottom:12px">
          <strong>{{name}} — {{position}}</strong>
          <div class="muted">
            {{startDate}}{{#endDate}} — {{endDate}}{{/endDate}} • {{location}}
          </div>
          <div style="margin-top:6px">{{summary}}</div>

          {{#highlights}}
          <ul>
            {{#.}}
              <li>{{.}}</li>
            {{/.}}
          </ul>
          {{/highlights}}
        </div>
        {{/work}}

      </div>

      <div class="section">
        <h2>Education</h2>

        {{#education}}
        <div style="margin-bottom:10px">
          <strong>{{institution}}</strong>
          <div class="muted">
            {{studyType}} — {{area}} • {{startDate}}{{#endDate}} — {{endDate}}{{/endDate}}
          </div>
        </div>
        {{/education}}

      </div>
    </section>

    <aside>
      <div class="section">
        <h2>Skills</h2>
        
        {{#skills}}
          <div style="margin-bottom:8px">
            <strong>{{name}}</strong>
            <div class="muted">
              {{#keywords}}
                {{#.}}
                  {{.}}{{^last}}, {{/last}}
                {{/.}}
              {{/keywords}}
            </div>
          </div>
        {{/skills}}

      </div>

      <div class="section">
        <h2>Meta</h2>
        <div id="meta" class="muted">Theme: {{meta.theme}}</div>
      </div>
    </aside>
  </main>
</body>
</html>
